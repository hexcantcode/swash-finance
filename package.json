{
  "name": "copytrade",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @copytrade/web dev",
    "worker": "pnpm --filter @copytrade/worker run",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "lint": "pnpm -r lint",
    "format": "prettier --write . --cache",
    "format:check": "prettier --check . --cache",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @copytrade/db generate",
    "db:migrate": "pnpm --filter @copytrade/db migrate",
    "db:studio": "pnpm --filter @copytrade/db studio",
    "bootstrap": "pnpm --filter @copytrade/worker run bootstrap",
    "leaderboard": "pnpm --filter @copytrade/worker run leaderboard",
    "score": "pnpm --filter @copytrade/worker run score",
    "refresh-queue": "pnpm --filter @copytrade/worker run refresh-queue"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.7.3",
    "tsx": "^4.19.2"
  }
}
