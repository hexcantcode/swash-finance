{
  "name": "copytrade",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @copytrade/api dev",
    "worker": "pnpm --filter @copytrade/worker run",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "lint": "pnpm -r lint",
    "format": "prettier --write . --cache",
    "format:check": "prettier --check . --cache",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @copytrade/db generate",
    "db:migrate": "pnpm --filter @copytrade/db migrate",
    "db:studio": "pnpm --filter @copytrade/db studio",
    "stack:start": "mkdir -p logs && pm2 start ecosystem.config.cjs",
    "stack:stop": "pm2 stop ecosystem.config.cjs",
    "stack:restart": "pm2 restart ecosystem.config.cjs",
    "stack:status": "pm2 status",
    "stack:logs": "pm2 logs",
    "stack:delete": "pm2 delete ecosystem.config.cjs"
  },
  "devDependencies": {
    "pm2": "^7.0.1",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
