# Copy to .env and fill in values. Never commit .env.

# Postgres connection (Neon dev branch in development)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Hyperliquid endpoints
HL_API_URL=https://api.hyperliquid.xyz
HL_INFO_URL=https://api.hyperliquid.xyz/info
HL_WS_URL=wss://api.hyperliquid.xyz/ws

# Worker tuning
LOG_LEVEL=info
HL_REST_WEIGHT_BUDGET_PER_MIN=800
WORKER_REGION=local

# Bootstrap discovery sweep
BOOTSTRAP_SWEEP_SECONDS=120
BOOTSTRAP_SWEEP_TOP_COINS=20

# On-disk HL response cache (relative to apps/worker)
HL_CACHE_DIR=.cache/hl
HL_CACHE_TTL_SECONDS=86400
