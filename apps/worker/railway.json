{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "corepack enable && pnpm install --frozen-lockfile --ignore-scripts"
  },
  "deploy": {
    "startCommand": "pnpm --filter @copytrade/worker run cohort-snapshot",
    "cronSchedule": "1-59/5 * * * *",
    "restartPolicyType": "NEVER"
  }
}
